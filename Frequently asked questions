<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>FAQ - Loan Business</title>
<style>
    body {
        font-family: Arial;
        margin: 20px;
    }
    details {
        margin-bottom: 10px;
        padding: 10px;
        background-color: #f2f2f2;
        border-radius: 5px;
    }
    summary {
        font-weight: bold;
        cursor: pointer;
    }
</style>
